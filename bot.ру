async def clan_upgrade(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if len(context.args) < 2:
        await update.message.reply_text("❌ Использование: /clan up [коллектор/опыт/удвоение]")
        return
    upgrade = context.args[1].lower()
    session = Session()
    user = session.query(User).filter_by(user_id=update.effective_user.id).first()
    if not user or not user.clan_id:
        await update.message.reply_text("❌ Вы не в клане.")
        session.close()
        return
    clan = session.query(Clan).filter_by(id=user.clan_id).first()
    if clan.leader_id != user.user_id:
        await update.message.reply_text("❌ Только лидер может улучшать клан.")
        session.close()
        return
    cost = 0
    if upgrade == 'коллектор':
        if clan.collect_bonus >= 10:
            await update.message.reply_text("❌ Максимальный уровень.")
            session.close()
            return
        cost = 50
        clan.collect_bonus += 1
    elif upgrade == 'опыт':
        if clan.exp_bonus >= 10:
            await update.message.reply_text("❌ Максимальный уровень.")
            session.close()
            return
        cost = 30
        clan.exp_bonus += 1
    elif upgrade == 'удвоение':
        if clan.double_bonus >= 10:
            await update.message.reply_text("❌ Максимальный уровень.")
            session.close()
            return
        cost = 25
        clan.double_bonus += 1
    else:
        await update.message.reply_text("❌ Неверный тип улучшения.")
        session.close()
        return
    if clan.treasury_crystals < cost:
        await update.message.reply_text(f"❌ Не хватает кристаллов. Нужно {cost}.")
        session.close()
        return
    clan.treasury_crystals -= cost
    session.commit()
    await update.message.reply_text(f"✅ Улучшение {upgrade} повышено до {getattr(clan, upgrade+'_bonus')} уровня.")
    session.close()

