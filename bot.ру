async def admin_item(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not await is_admin(update, context):
        await update.message.reply_text("❌ Нет прав")
        return
    if len(context.args) < 4:
        await update.message.reply_text("❌ /item give/take @ник [предмет] [кол-во]")
        return
    action = context.args[0].lower()
    username = context.args[1].lstrip('@')
    item = context.args[2].lower()
    try:
        count = int(context.args[3])
        if count <= 0:
            await update.message.reply_text("❌ Положительное число")
            return
    except ValueError:
        await update.message.reply_text("❌ Введите число")
        return
    session = Session()
    try:
        user = session.query(User).filter_by(username=username).first()
        if not user:
            await update.message.reply_text("❌ Пользователь не найден")
            return
        now = datetime.now()
        if action == 'give':
            if item == 'щит':
                user.shield_until = now + timedelta(days=7)
            elif item == 'камуфляж':
                user.camouflage_until = now + timedelta(days=7)
            elif item == 'гарпун':
                user.has_harpoon = True
            elif item == 'винтовка':
                user.has_rifle = True
            elif item == 'металлоискатель':
                user.detectors += count
            elif item == 'броня1':
                user.armor_rank = 1
            elif item == 'броня2':
                user.armor_rank = 2
            elif item == 'броня3':
                user.armor_rank = 3
            elif item == 'аптечка':
                user.medkits = min(user.medkits + count, MAX_MEDKITS)
            elif item == 'энергетик':
                user.energy_drink_until = now + timedelta(days=1)
            elif item == 'редуктор':
                user.cooldown_reducer_until = now + timedelta(days=3)
            elif item == 'тересса':
                user.teressa = True
            else:
                await update.message.reply_text(f"❌ Неизвестный предмет: {item}")
                return
            session.commit()
            await update.message.reply_text(f"✅ *Выдано {item} x{count} @{username}*", parse_mode='Markdown')
        elif action == 'take':
            if item == 'щит':
                user.shield_until = None
            elif item == 'камуфляж':
                user.camouflage_until = None
            elif item == 'гарпун':
                user.has_harpoon = False
            elif item == 'винтовка':
                user.has_rifle = False
            elif item == 'металлоискатель':
                user.detectors = max(0, user.detectors - count)
            elif item == 'броня1':
                if user.armor_rank == 1:
                    user.armor_rank = 0
            elif item == 'броня2':
                if user.armor_rank == 2:
                    user.armor_rank = 0
            elif item == 'броня3':
                if user.armor_rank == 3:
                    user.armor_rank = 0
            elif item == 'аптечка':
                user.medkits = max(0, user.medkits - count)
            elif item == 'энергетик':
                user.energy_drink_until = None
            elif item == 'редуктор':
                user.cooldown_reducer_until = None
            elif item == 'тересса':
                user.teressa = False
            else:
                await update.message.reply_text(f"❌ Неизвестный предмет: {item}")
                return
            session.commit()
            await update.message.reply_text(f"✅ *Забрано {item} x{count} у @{username}*", parse_mode='Markdown')
        else:
            await update.message.reply_text("❌ give или take")
    except Exception as e:
        logger.error(f"Error in admin_item: {e}")
        session.rollback()
        await update.message.reply_text("❌ Ошибка")
    finally:
        Session.remove()

