async def admin_item(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not await is_admin(update, context):
        await update.message.reply_text("❌ Нет прав.")
        return
    if len(context.args) < 4:
        await update.message.reply_text("❌ Использование: /item give/take @ник [предмет] [кол-во]")
        return
    action = context.args[0].lower()
    username = context.args[1].lstrip('@')
    item = context.args[2].lower()
    try:
        count = int(context.args[3])
    except:
        await update.message.reply_text("❌ Введите число.")
        return
    session = Session()
    user = session.query(User).filter_by(username=username).first()
    if not user:
        await update.message.reply_text("❌ Пользователь не найден.")
        session.close()
        return
    
    if action == 'give':
        now = datetime.now()
        if item == 'щит':
            user.shield_until = now + timedelta(days=7)
        elif item == 'камуфляж':
            user.camouflage_until = now + timedelta(days=7)
        elif item == 'гарпун':
            user.harpoons += count
        elif item == 'винтовка':
            user.rifles += count
        elif item == 'металлоискатель':
            user.detectors += count
        elif item == 'броня1':
            user.armor_rank = 1
        elif item == 'броня2':
            user.armor_rank = 2
        elif item == 'броня3':
            user.armor_rank = 3
        elif item == 'аптечка':
            user.medkits = min(user.medkits + count, 2)
        else:
            await update.message.reply_text(f"❌ Неизвестный предмет: {item}")
            session.close()
            return
        session.commit()
        await update.message.reply_text(f"✅ Выдано {item} x{count} @{username}.")
    elif action == 'take':
        if item == 'щит':
            user.shield_until = None
        elif item == 'камуфляж':
            user.camouflage_until = None
        elif item == 'гарпун':
            user.harpoons = max(0, user.harpoons - count)
        elif item == 'винтовка':
            user.rifles = max(0, user.rifles - count)
        elif item == 'металлоискатель':
            user.detectors = max(0, user.detectors - count)
        elif item == 'броня1' or item == 'броня2' or item == 'броня3':
            user.armor_rank = 0
        elif item == 'аптечка':
            user.medkits = max(0, user.medkits - count)
        else:
            await update.message.reply_text(f"❌ Неизвестный предмет: {item}")
            session.close()
            return
        session.commit()
        await update.message.reply_text(f"✅ Забрано {item} x{count} у @{username}.")
    else:
        await update.message.reply_text("❌ Действие должно быть give или take.")
    session.close()

