async def radio(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Отправить сообщение всем игрокам через радио"""
    if not context.args:
        await update.message.reply_text("❌ /radio [текст]")
        return
    session = Session()
    try:
        user = session.query(User).filter_by(user_id=update.effective_user.id).first()
        if not user:
            await update.message.reply_text("❌ Сначала /start")
            return
        if not user.radio_active:
            await update.message.reply_text("❌ Радио не активировано! Используйте /radion [код]")
            return
        if user.radio_banned:
            await update.message.reply_text("❌ Вы заблокированы в радио!")
            return
        
        msg = ' '.join(context.args)
        
        # Проверка длины (200 символов)
        if len(msg) > 200:
            await update.message.reply_text("❌ Сообщение не более 200 символов!")
            return
        
        # Проверка частоты (1 минута)
        last_radio = context.user_data.get('last_radio')
        if last_radio and datetime.now() - last_radio < timedelta(minutes=1):
            remaining = timedelta(minutes=1) - (datetime.now() - last_radio)
            seconds = remaining.seconds
            await update.message.reply_text(f"❌ Следующее сообщение через {seconds} секунд!")
            return
        
        context.user_data['last_radio'] = datetime.now()
        
        text = f"📻 *Радио Пустоши*\n\n🎙️ *Ведущий:* @{user.username}\n\n📢 {msg}"
        
        # Отправляем в личку всем игрокам
        users = session.query(User).all()
        sent_private = 0
        for u in users:
            if u.notifications_enabled:
                try:
                    await context.bot.send_message(u.user_id, text, parse_mode='Markdown')
                    sent_private += 1
                except:
                    pass
        
        # Отправляем в группы, где есть бот
        sent_groups = 0
        groups = set()
        async for update_obj in context.application.get_updates():
            if update_obj.message and update_obj.message.chat.type in ['group', 'supergroup']:
                groups.add(update_obj.message.chat.id)
        
        for chat_id in groups:
            try:
                await context.bot.send_message(chat_id, text, parse_mode='Markdown')
                sent_groups += 1
            except:
                pass
        
        await update.message.reply_text(
            f"✅ *Сообщение отправлено!*\n\n"
            f"📨 В личку: {sent_private}\n"
            f"👥 В группы: {sent_groups}\n"
            f"📻 Вещание успешно завершено.",
            parse_mode='Markdown'
        )
    except Exception as e:
        logger.error(f"Error in radio: {e}")
        await update.message.reply_text("❌ Ошибка при отправке радиосообщения")
    finally:
        Session.remove()

