            target_desc = "легендарное чудовище"
            user.bosses_killed += 1
        
        user.mutants_killed += 1
        survived = True
        death_msg = ""
        
        # Выживание на боссе
        if reward == 1000:
            survive_chance = calculate_survive_chance(user)
            if random.random() * 100 > survive_chance:
                survived = False
                if user.medkits > 0:
                    user.medkits -= 1
