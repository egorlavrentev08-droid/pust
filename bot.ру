def calculate_survive_chance(user, target_level):
    """Расчет шанса выжить на охоте"""
    if user.teressa:
        return 100
    
    armor_bonus = {
        'light': 25,
        'heavy': 40,
        'tactical': 50,
        'reinforced': 60,
        'power': 75
    }
    
    base = 10
    if user.armor_type and user.armor_type in armor_bonus:
        base = armor_bonus[user.armor_type]
    
    # Мутант 3 уровня даёт +25%
    if target_level == 3:
        base = min(100, base + 25)
    
    if user.medkits > 0:
        base = min(100, base + 25)
    
    return base

