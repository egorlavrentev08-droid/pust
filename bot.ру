        return
    
    item_name = context.args[0].lower()
    count = 1
    if len(context.args) > 1:
        try:
            count = int(context.args[1])
            if count <= 0 or count > 100:
                await update.message.reply_text("❌ 1-100")
                return
        except ValueError:
            await update.message.reply_text("❌ Введите число")
            return
    
