async def admin_manage(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id not in SUPER_ADMIN_IDS:
        await update.message.reply_text("❌ Только главный администратор может управлять админами!")
        return
    if len(context.args) < 2:
        await update.message.reply_text(
            "👑 *Управление администраторами*\n━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
            "/admin add @ник — добавить администратора\n"
            "/admin remove @ник — удалить администратора\n"
            "/admin block @ник — заблокировать администратора\n"
            "/admin unblock @ник — разблокировать администратора\n"
            "/admin list — список всех администраторов",
            parse_mode='Markdown'
        )
        return
    action = context.args[0].lower()
    username = context.args[1].lstrip('@')
    session = Session()
    try:
        user = session.query(User).filter_by(username=username).first()
        if not user:
            await update.message.reply_text(f"❌ Пользователь @{username} не найден!")
            return
        if action == 'add':
            if user.is_admin:
                await update.message.reply_text(f"❌ @{username} уже является администратором!")
                return
            user.is_admin = True
            user.is_blocked = False
            session.commit()
            await update.message.reply_text(f"✅ *@{username} добавлен в администраторы!*", parse_mode='Markdown')
            try:
                await context.bot.send_message(
                    chat_id=user.user_id,
                    text=f"👑 *Поздравляем!* Вы назначены администратором Пустоши!"
                )
            except:
                pass
        elif action == 'remove':
            if not user.is_admin:
                await update.message.reply_text(f"❌ @{username} не является администратором!")
                return
            user.is_admin = False
            user.is_blocked = False
            session.commit()
            await update.message.reply_text(f"✅ *@{username} удалён из администраторов!*", parse_mode='Markdown')
        elif action == 'block':
            if not user.is_admin:
                await update.message.reply_text(f"❌ @{username} не является администратором!")
                return
            if user.user_id in SUPER_ADMIN_IDS:
                await update.message.reply_text(f"❌ Нельзя заблокировать главного администратора!")
                return
            user.is_blocked = True
            session.commit()
            await update.message.reply_text(f"✅ *@{username} заблокирован!* Админ-команды недоступны.", parse_mode='Markdown')
        elif action == 'unblock':
            if not user.is_admin:
                await update.message.reply_text(f"❌ @{username} не является администратором!")
                return
            user.is_blocked = False
            session.commit()
            await update.message.reply_text(f"✅ *@{username} разблокирован!*", parse_mode='Markdown')
        elif action == 'list':
            admins = session.query(User).filter(User.is_admin == True).all()
            if not admins:
                await update.message.reply_text("📋 *Нет администраторов*", parse_mode='Markdown')
                return
            text = "👑 *Список администраторов*\n━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
            for i, a in enumerate(admins, 1):
                status = "🔴 ЗАБЛОКИРОВАН" if a.is_blocked else "🟢 АКТИВЕН"
                main = " (ГЛАВНЫЙ)" if a.user_id in SUPER_ADMIN_IDS else ""
                text += f"{i}. *{a.username or f'ID:{a.user_id}'}*{main}\n"
                text += f"   📊 Статус: {status}\n"
                text += f"   📊 Уровень: {a.level}\n"
                text += f"   ☢️ RC: {a.radcoins:.0f}\n\n"
            await update.message.reply_text(text, parse_mode='Markdown')
        else:
            await update.message.reply_text("❌ Используйте: add, remove, block, unblock, list")
    except Exception as e:
        logger.error(f"Error in admin_manage: {e}")
        session.rollback()
        await update.message.reply_text("❌ Ошибка")
    finally:
        Session.remove()

