    try:
        count = int(context.args[3])
        if count <= 0:
            await update.message.reply_text("❌ Положительное число")
            return
    except ValueError:
        await update.message.reply_text("❌ Введите число")
        return
    session = Session()
    try:
        user = session.query(User).filter_by(username=username).first()
        if not user:
            await update.message.reply_text("❌ Пользователь не найден")
            return
        now = datetime.now()
        if action == 'give':
            if item == 'щит':
                user.shield_until = now + timedelta(days=7)
            elif item == 'камуфляж':
                user.camouflage_until = now + timedelta(days=7)
            elif item == 'гарпун':
                user.weapon = 'harpoon'
            elif item == 'винтовка':
                user.weapon = 'rifle'
            elif item == 'ружье':
                user.weapon = 'shotgun'
            elif item == 'гаусс':
                user.weapon = 'gauss'
            elif item == 'металлоискатель':
                user.detectors += count
            elif item == 'броня1':
                user.armor_type = 'light'
            elif item == 'броня2':
                user.armor_type = 'heavy'
            elif item == 'броня3':
                user.armor_type = 'tactical'
            elif item == 'броня4':
                user.armor_type = 'reinforced'
            elif item == 'броня5':
                user.armor_type = 'power'
            elif item == 'аптечка':
                user.medkits = min(user.medkits + count, MAX_MEDKITS)
            elif item == 'энергетик':
                user.energy_drink_until = now + timedelta(days=1)
            elif item == 'редуктор':
                user.cooldown_reducer_until = now + timedelta(days=3)
            elif item == 'тересса':
                user.teressa = True
            else:
                await update.message.reply_text(f"❌ Неизвестный предмет: {item}")
                return
            session.commit()
            await update.message.reply_text(f"✅ *Выдано {item} x{count} @{username}*", parse_mode='Markdown')
        elif action == 'take':
            if item == 'щит':
                user.shield_until = None
            elif item == 'камуфляж':
                user.camouflage_until = None
            elif item == 'гарпун':
                user.weapon = None
            elif item == 'винтовка':
                user.weapon = None
            elif item == 'ружье':
                user.weapon = None
            elif item == 'гаусс':
                user.weapon = None
            elif item == 'металлоискатель':
                user.detectors = max(0, user.detectors - count)
            elif item == 'броня1':
                if user.armor_type == 'light':
                    user.armor_type = None
            elif item == 'броня2':
                if user.armor_type == 'heavy':
                    user.armor_type = None
            elif item == 'броня3':
