async def casino(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not context.args:
        await update.message.reply_text("❌ Использование: /casino [сумма]")
        return
    try:
        bet = int(context.args[0])
    except:
        await update.message.reply_text("❌ Введите число.")
        return
    
    session = Session()
    user = session.query(User).filter_by(user_id=update.effective_user.id).first()
    if not user:
        await update.message.reply_text("❌ Сначала используйте /start")
        session.close()
        return
    
    if bet <= 0 or user.radcoins < bet:
        await update.message.reply_text("❌ Недостаточно RC.")
        session.close()
        return
    
    user.radcoins -= bet
    if random.random() < 0.03:
        win = bet * 50
        user.radcoins += win
        session.commit()
        await update.message.reply_text(f"🎰 ДЖЕКПОТ! +{win} RC. Баланс: {user.radcoins:.0f} RC")
    else:
        session.commit()
        await update.message.reply_text(f"💀 Проигрыш! -{bet} RC. Баланс: {user.radcoins:.0f} RC")
    session.close()

