async def collect(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    username = update.effective_user.username
    session = Session()
    try:
        user = session.query(User).filter_by(user_id=user_id).first()
        if not user:
            user = User(user_id=user_id, username=username)
            session.add(user)
            session.commit()
        
        now = datetime.now()
        if user.next_collection_time and now < user.next_collection_time:
            remaining = user.next_collection_time - now
            hours = remaining.seconds // 3600
            minutes = (remaining.seconds % 3600) // 60
            await update.message.reply_text(f"⏰ *Следующий сбор через {hours}ч {minutes}мин.*", parse_mode='Markdown')
            return
        
        actual_level = min(user.level, MAX_LEVEL)
        if user.energy_drink_until and user.energy_drink_until > now:
            actual_level = min(user.level + 5, MAX_LEVEL)
        
        base_rc = calculate_reward(actual_level)
        exp_gain = calculate_experience()
        
        # Бонусы локации
        location = user.location if hasattr(user, 'location') else 'normal'
        rc_mult = 1
        rf_mult = 1
        exp_mult = 1
        pet_mult = 1
        chest_mult = 1
        location_msg = ""
        
        if location == 'military':
            chest_mult = 3
            rc_mult = 0
            rf_mult = 0
            exp_gain = random.randint(25, 50)
            location_msg = "🏚️ *Военка* — вы обыскиваете руины в поисках сундуков"
        elif location == 'city':
            rc_mult = 1.5
            rf_mult = 0.5
            location_msg = "🏙️ *Город* — вы бродите по пустынным улицам"
        elif location == 'wasteland':
            rf_mult = 1.5
            rc_mult = 0.7
            location_msg = "🌄 *Пустошь* — вы крадётесь по радиоактивным землям"
        elif location == 'lab':
            exp_mult = 2
            rc_mult = 0.5
            location_msg = "🧪 *Лаба* — вы исследуете заброшенную лабораторию"
        elif location == 'forest':
            pet_mult = 2
            rc_mult = 0.8
            rf_mult = 0
            exp_gain = random.randint(30, 80)
            location_msg = "🌲 *Лес* — вы пробираетесь через чащу"
        elif location == 'swamp':
            rc_mult = 2
            rf_mult = 0.5
            location_msg = "🌊 *Болота* — вы осторожно ступаете по зыбкой почве"
        elif location == 'market':
            rc_mult = 1.2
            rf_mult = 0
            chest_mult = 2
            exp_gain = random.randint(10, 30)
            location_msg = "🎪 *Рынок* — вы бродите между прилавками"
        else:
            location_msg = "🌍 *Пустошь* — вы отправляетесь в знакомые места"
        
        # Аномалии
        anomaly_msg = ""
        phase = context.bot_data.get('phase', 1)
        if phase >= 3:
            anomaly_roll = random.random()
            if anomaly_roll < 0.1:
                base_rc = int(base_rc * 1.3)
                anomaly_msg = "\n✨ *Аномалия ДОБЫТЧИК!* +30% к добыче! ✨"
            elif anomaly_roll < 0.2:
                anomaly_msg = "\n🕸️ *Аномалия ЛОВЕЦ!* Мутанты чуют вас издалека! 🕸️"
            elif anomaly_roll < 0.2001:
                reduction = random.randint(1, 5)
                actual_level = max(1, actual_level - reduction)
                anomaly_msg = f"\n🧠 *Аномалия СКЛЕРОЗИК!* Ваш уровень временно снижен на {reduction}! 🧠"
        
        # Клановый бонус
        clan_bonus = 0
        clan = None
        if user.clan_id:
            clan = session.query(Clan).filter_by(id=user.clan_id).first()
            if clan:
                clan_bonus = clan.collect_bonus
                exp_gain = int(exp_gain * (1 + clan.exp_bonus * 0.05))
        
        rc_gain = int(base_rc * (1 + clan_bonus / 100) * rc_mult)
        exp_gain = int(exp_gain * exp_mult)
        fragment_gain = 0
        
        # Питомцы
        if user.pet == 'рысь':
            rc_gain = int(rc_gain * 1.1)
        if user.pet == 'попугай':
            exp_gain = int(exp_gain * 1.4)
        
        # Множители
        multiplier = 1
        double_chance = 9
        if clan:
            double_chance += clan.double_bonus
        if random.random() < 0.01:
            multiplier = 5
            user.crit_collects += 1
        elif random.random() < double_chance / 100:
            multiplier = 2
            user.crit_collects += 1
        rc_gain *= multiplier
        
        # Фрагменты
        fragment_chance = 1
        if user.pet == 'овчарка':
            fragment_chance += 5
        if random.random() < fragment_chance / 100:
            fragment_gain = random.randint(1, 5)
        fragment_gain = int(fragment_gain * rf_mult)
        
        # Металлоискатель
        if user.detectors > 0:
            user.detectors -= 1
            rc_gain = int(rc_gain * 0.3)
            if random.random() < 0.25:
                fragment_gain = 10
        
        # Бонус класса
        rc_gain, fragment_gain, exp_gain = apply_class_bonus(user, rc_gain, fragment_gain, exp_gain)
        
        # Встреча с мутантом
        meet_chance = 10
        if anomaly_msg and "ЛОВЕЦ" in anomaly_msg:
            meet_chance = 90
        if user.camouflage_until and user.camouflage_until > now:
            meet_chance = 1
        if user.pet == 'лис':
            meet_chance = meet_chance // 2 if meet_chance > 1 else 1
        
        lost_rc = 0
        if random.random() < meet_chance / 100:
            loss_percent = 50
            if user.shield_until and user.shield_until > now:
                loss_percent = 10
            lost_rc = int(rc_gain * loss_percent / 100)
            rc_gain -= lost_rc
        
        # Кристаллы
        crystal_gain = 0
        if clan:
            crystal_gain = random.randint(1, 5)
            if user.pet == 'пума':
                crystal_gain = int(crystal_gain * 1.5)
            clan.treasury_crystals += crystal_gain
        
        user.radcoins += rc_gain
        user.radfragments += fragment_gain
        user.experience += exp_gain
        user.total_collects += 1
        user.total_rc_earned += rc_gain
        if rc_gain > user.best_collect:
            user.best_collect = rc_gain
        
        level_up = False
        while user.level < MAX_LEVEL and user.experience >= get_exp_for_level(user.level + 1):
            user.level += 1
            level_up = True
        
        interval = get_random_interval(user)
        user.last_collection = now
        user.next_collection_time = now + timedelta(minutes=interval)
        
        last_date = user.last_collect_date.date() if user.last_collect_date else None
        today = now.date()
        if last_date == today - timedelta(days=1):
            user.daily_streak += 1
        elif last_date != today:
            user.daily_streak = 1
        user.last_collect_date = now
        
        # Питомец
        pet_encounter = None
        if phase >= 2 and user.level >= 2:
            if random.random() < 0.005 * pet_mult:
                pets = ['овчарка', 'волк', 'алабай', 'рысь', 'пума', 'попугай', 'лис', 'кайот']
                weights = [1, 1, 1, 1, 1, 1, 1, 0.5]
                pet_encounter = random.choices(pets, weights=weights)[0]
        
        new_achievements = check_achievements(user, session)
        
        # Сундуки
        chest_found = None
        if phase >= 2 and chest_mult > 0:
            chest_roll = random.random() * 100
            if chest_roll < 1 * chest_mult:
                user.chest_legendary += 1
                chest_found = "🟠 Легендарный сундук"
            elif chest_roll < 4 * chest_mult:
                user.chest_mythic += 1
                chest_found = "🟡 Мифический сундук"
            elif chest_roll < 8 * chest_mult:
                user.chest_epic += 1
                chest_found = "🟣 Эпический сундук"
            elif chest_roll < 15 * chest_mult:
                user.chest_rare += 1
                chest_found = "🔵 Редкий сундук"
            elif chest_roll < 25 * chest_mult:
                user.chest_common += 1
                chest_found = "🟢 Обычный сундук"
        
        session.commit()
        
        msg = f"🌄 {location_msg}\n\n🔍 +{rc_gain} RC, +{exp_gain} опыта"
        if multiplier > 1:
            msg += f" ✨ x{multiplier}"
        if fragment_gain > 0:
            msg += f"\n☣️ +{fragment_gain} RF"
        if lost_rc > 0:
            msg += f"\n😈 Мутант украл {lost_rc} RC"
        if crystal_gain > 0:
            msg += f"\n💎 +{crystal_gain} RCr"
        if level_up:
            msg += f"\n🎉 УРОВЕНЬ {user.level}"
        if anomaly_msg:
            msg += anomaly_msg
        if new_achievements:
            msg += f"\n🏆 {', '.join(new_achievements)}"
        if user.pet:
            pet_msgs = {
                'овчарка': "🐕 Овчарка охраняет",
                'волк': "🐺 Волк предупреждает",
                'алабай': "🐕‍🦺 Алабай ведёт",
                'рысь': "🐈 Рысь крадётся",
                'пума': "🐆 Пума приносит кристаллы",
                'попугай': "🦜 Попугай ускоряет",
                'лис': "🦊 Лис скрывает",
                'кайот': "🐕 Кайот ускоряет"
            }
            msg += f"\n{pet_msgs.get(user.pet, '🐾 Питомец рядом')}"
        if pet_encounter:
            msg += f"\n\n🐾 Встретили {pet_encounter}! /pet accept"
            context.user_data['pending_pet'] = pet_encounter
        msg += f"\n\n⏰ Следующий сбор через {interval//60}ч {interval%60}мин"
        if chest_found:
            msg += f"\n\n🎁 Нашли {chest_found}!"
        
        await update.message.reply_text(msg, parse_mode='Markdown')
        
        if user.notifications_enabled:
            scheduler.add_job(
                lambda: context.bot.send_message(user.user_id, "🌄 Пустошь восстановилась! /collect"),
                'date', run_date=user.next_collection_time
            )
    except Exception as e:
        logger.error(f"Error in collect: {e}")
        session.rollback()
        await update.message.reply_text("❌ Ошибка")
    finally:
        Session.remove()

