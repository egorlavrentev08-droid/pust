async def collect(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    username = update.effective_user.username
    session = Session()
    user = session.query(User).filter_by(user_id=user_id).first()
    if not user:
        user = User(user_id=user_id, username=username)
        session.add(user)
        session.commit()
    
    now = datetime.now()
    if user.next_collection_time and now < user.next_collection_time:
        remaining = user.next_collection_time - now
        hours = remaining.seconds // 3600
        minutes = (remaining.seconds % 3600) // 60
        await update.message.reply_text(f"⏰ Следующий сбор через {hours}ч {minutes}мин.")
        session.close()
        return
    
    actual_level = user.level
    if user.energy_drink_until and user.energy_drink_until > now:
        actual_level = min(user.level + 5, 100)
    
    base_rc = calculate_reward(actual_level)
    exp_gain = calculate_experience()
    
    rc_gain = base_rc
    if user.pet == 'рысь':
        rc_gain = int(rc_gain * 1.1)
    if user.pet == 'попугай':
        exp_gain = int(exp_gain * 1.4)
    
    multiplier = 1
    double_chance = 9
    if random.random() < 0.01:
        multiplier = 5
        user.crit_collects += 1
    elif random.random() < double_chance / 100:
        multiplier = 2
        user.crit_collects += 1
    rc_gain *= multiplier
    
    fragment_gain = 0
    fragment_chance = 1
    if user.pet == 'овчарка':
        fragment_chance += 5
    if random.random() < fragment_chance / 100:
        fragment_gain = 1
    
    if user.detectors > 0:
        user.detectors -= 1
        rc_gain = int(rc_gain * 0.3)
        if random.random() < 0.25:
            fragment_gain = 10
    
    meet_chance = 10
    if user.camouflage_until and user.camouflage_until > now:
        meet_chance = 1
    if user.pet == 'лис':
        meet_chance = meet_chance // 2 if meet_chance > 1 else 1
    
    lost_rc = 0
    if random.random() < meet_chance / 100:
        loss_percent = 50
        if user.shield_until and user.shield_until > now:
            loss_percent = 10
        lost_rc = int(rc_gain * loss_percent / 100)
        rc_gain -= lost_rc
    
    user.radcoins += rc_gain
    user.radfragments += fragment_gain
    user.experience += exp_gain
    user.total_collects += 1
    user.total_rc_earned += rc_gain
    if rc_gain > user.best_collect:
        user.best_collect = rc_gain
    
    level_up = False
    while user.experience >= get_exp_for_level(user.level + 1):
        user.level += 1
        level_up = True
    
    interval = get_random_interval(user)
    user.last_collection = now
    user.next_collection_time = now + timedelta(minutes=interval)
    
    last_date = user.last_collect_date.date() if user.last_collect_date else None
    today = now.date()
    if last_date == today - timedelta(days=1):
        user.daily_streak += 1
    elif last_date != today:
        user.daily_streak = 1
    user.last_collect_date = now
    
    session.commit()
    
    msg = f"🎲 Сбор: +{rc_gain} RC, +{exp_gain} опыта."
    if multiplier > 1:
        msg += f" ✨ x{multiplier}!"
    if fragment_gain > 0:
        msg += f" ☣️ +{fragment_gain} RF!"
    if lost_rc > 0:
        msg += f" 😈 Мутант украл {lost_rc} RC!"
    if level_up:
        msg += f" 🎉 Новый уровень: {user.level}!"
    
    next_hours = interval // 60
    next_minutes = interval % 60
    msg += f"\n⏰ Следующий сбор через {next_hours}ч {next_minutes}мин."
    
    await update.message.reply_text(msg)
    session.close()

