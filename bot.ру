async def buy(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not context.args:
        await update.message.reply_text("❌ Пример: /buy аптечка(2); броня1(1)")
        return
    args = ' '.join(context.args)
    pattern = r'([а-яё]+)\((\d+)\)'
    matches = re.findall(pattern, args)
    if not matches:
        await update.message.reply_text("❌ Неверный формат.")
        return
    
    session = Session()
    user = session.query(User).filter_by(user_id=update.effective_user.id).first()
    if not user:
        await update.message.reply_text("❌ Сначала используйте /start")
        session.close()
        return
    
    prices = {
        'щит': 10, 'камуфляж': 50, 'гарпун': 5, 'винтовка': 50, 'металлоискатель': 3,
        'броня1': 1, 'броня2': 3, 'броня3': 10, 'аптечка': 5
    }
    total_cost = 0
    items = []
    for name, count in matches:
        count = int(count)
        if name not in prices:
            await update.message.reply_text(f"❌ Неизвестный товар: {name}")
            session.close()
            return
        total_cost += prices[name] * count
        items.append((name, count))
    
    if user.radfragments < total_cost:
        await update.message.reply_text(f"❌ Не хватает RF. Нужно {total_cost}")
        session.close()
        return
    
    user.radfragments -= total_cost
    now = datetime.now()
    for name, count in items:
        if name == 'щит':
            user.shield_until = now + timedelta(days=7)
        elif name == 'камуфляж':
            user.camouflage_until = now + timedelta(days=7)
        elif name == 'гарпун':
            user.harpoons += count
        elif name == 'винтовка':
            user.rifles += count
        elif name == 'металлоискатель':
            user.detectors += count
        elif name == 'броня1':
            user.armor_rank = 1
        elif name == 'броня2':
            user.armor_rank = 2
        elif name == 'броня3':
            user.armor_rank = 3
        elif name == 'аптечка':
            user.medkits = min(user.medkits + count, 2)
    
    session.commit()
    await update.message.reply_text(f"✅ Куплено: {', '.join(f'{n}x{c}' for n,c in items)}")
    session.close()

