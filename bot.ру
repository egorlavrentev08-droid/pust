                user.chest_rare += 1
                chest_found = "🔵 Редкий сундук"
            elif chest_roll < 11.39:
                user.chest_common += 1
                chest_found = "🟢 Обычный сундук"
        
        session.commit()
        
        msg = f"🌄 *Вы отправляетесь в Пустошь...*\n\n"
        msg += f"🔍 Вы находите **{rc_gain}** ☢️ *РадКоинов* и получаете **{exp_gain}** ⚠️ *опыта*!"
        
        if multiplier > 1:
            msg += f"\n✨ *УДАЧА!* Множитель x{multiplier}! ✨"
        if fragment_gain > 0:
            msg += f"\n☣️ *Вам везёт!* Вы находите **{fragment_gain}** РадФрагмент!"
        if lost_rc > 0:
            msg += f"\n😈 *МУТАНТ АТАКУЕТ!* Он крадёт {lost_rc} RC!"
        if crystal_gain > 0:
            msg += f"\n💎 *Клановые кристаллы:* +{crystal_gain} RCr!"
        if level_up:
            msg += f"\n🎉 *УРОВЕНЬ ПОВЫШЕН!* Теперь вы {user.level} уровень! 🎉"
        if anomaly_msg:
            msg += anomaly_msg
        if new_achievements:
            msg += f"\n🏆 *Новые достижения:* {', '.join(new_achievements)}! 🏆"
        
        if user.pet:
            pet_messages = {
                'овчарка': "🐕 *Овчарка преданно охраняет вас!*",
                'волк': "🐺 *Волк идёт рядом, его чутьё предупреждает об опасности!*",
                'алабай': "🐕‍🦺 *Алабай уверенно ведёт вас по тропам!*",
                'рысь': "🐈 *Рысь бесшумно крадётся впереди!*",
                'пума': "🐆 *Пума приносит удачу — кристаллы сами находят вас!*",
                'попугай': "🦜 *Попугай весело щебечет, ускоряя обучение!*",
                'лис': "🦊 *Лис хитро прищурился — мутанты не замечают вас!*",
                'кайот': "🐕 *Кайот нетерпеливо повизгивает — время до сбора сократилось вдвое!*"
            }
            msg += f"\n{pet_messages.get(user.pet, '🐾 *Ваш питомец рядом!*')}"
        
        if pet_encounter:
            msg += f"\n\n🐾 *Вы встречаете {pet_encounter}!*\nИспользуйте `/pet accept` чтобы приручить."
            context.user_data['pending_pet'] = pet_encounter
        
        next_hours = interval // 60
        next_minutes = interval % 60
        msg += f"\n\n⏰ *Пустошь восстановится через {next_hours}ч {next_minutes}мин.*"
        
        if chest_found:
            msg += f"\n\n🎁 *Вы нашли {chest_found}!*\nИспользуйте `/chest list` чтобы посмотреть сундуки."
        
        await update.message.reply_text(msg, parse_mode='Markdown')
        
        if user.notifications_enabled:
            schedule_notification(user.user_id, context.bot, 'collect', user.next_collection_time)
    
    except Exception as e:
        logger.error(f"Error in collect: {e}")
        session.rollback()
        await update.message.reply_text("❌ Ошибка.")
    
    finally:
        Session.remove()

