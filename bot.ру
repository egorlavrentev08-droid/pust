async def restore_backup(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Восстановить базу данных из бэкапа"""
    if not await is_admin(update, context):
        await update.message.reply_text("❌ Нет прав!")
        return
    
    if not context.args:
        await update.message.reply_text(
            "❌ /restore [имя_бэкапа]\n\nПример: `/restore radcoin_bot.db.backup_20260324_120000.db`",
            parse_mode='Markdown'
        )
        return
    
    backup_name = context.args[0]
    backup_path = os.path.join(BACKUP_DIR, backup_name)
    
    if not os.path.exists(backup_path):
        await update.message.reply_text(f"❌ Бэкап `{backup_name}` не найден!", parse_mode='Markdown')
        return
    
    # Делаем бэкап текущей БД перед восстановлением
    auto_backup()
    
    # Восстанавливаем базу
    shutil.copy(backup_path, 'radcoin_bot.db')
    
    await update.message.reply_text(
        f"✅ *База данных восстановлена из бэкапа!*\n\n"
        f"📁 Бэкап: `{backup_name}`\n\n"
        f"⚠️ *Перезапустите бота командой:* `python bot.py`",
        parse_mode='Markdown'
    )
    
    # Завершаем процесс
    os._exit(0)

