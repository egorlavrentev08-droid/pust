def check_achievements(user, session):
    achievements = json.loads(user.achievements) if user.achievements else []
    new_achievements = []
    
    if user.total_collects >= 10 and 'добытчик' not in achievements:
        new_achievements.append('добытчик')
    if user.level >= 10 and 'кандидат' not in achievements:
        new_achievements.append('кандидат')
    if user.level >= 50 and 'мастер' not in achievements:
        new_achievements.append('мастер')
    if user.level >= MAX_LEVEL and 'легенда' not in achievements:
        new_achievements.append('легенда')
    if user.daily_streak >= 7 and 'терпила' not in achievements:
        new_achievements.append('терпила')
    if user.daily_streak >= 30 and 'старатель' not in achievements:
        new_achievements.append('старатель')
    if user.total_purchases >= 10 and 'постоянный_клиент' not in achievements:
        new_achievements.append('постоянный_клиент')
    if user.radcoins >= 100000 and 'миллионер' not in achievements:
        new_achievements.append('миллионер')
    
    if new_achievements:
        achievements.extend(new_achievements)
        user.achievements = json.dumps(achievements)
        session.commit()
        return new_achievements
    return []

def calculate_survive_chance(user):
    if user.teressa:
        return 100
    base_chance = {0: 10, 1: 33, 2: 67, 3: 99}[user.armor_rank]
    if user.medkits > 0:
        base_chance = min(100, base_chance + 25)
    return base_chance

async def send_collect_notification(user_id: int, bot):
    try:
        await bot.send_message(
            chat_id=user_id,
            text="🌄 *Пустошь восстановилась!*\n\nВы снова можете отправиться на сбор ресурсов.\n\n🔔 Используйте `/collect`, чтобы начать поиск!",
            parse_mode='Markdown'
        )
    except Exception as e:
        logger.error(f"Failed to send collect notification: {e}")

async def send_hunt_notification(user_id: int, bot):
    try:
        await bot.send_message(
            chat_id=user_id,
            text="🏹 *Звери проснулись!*\n\nОхота на мутантов снова доступна.\n\n🔔 Используйте `/hunt`, чтобы отправиться в Пустошь!",
            parse_mode='Markdown'
        )
    except Exception as e:
        logger.error(f"Failed to send hunt notification: {e}")

def schedule_notification(user_id, bot, notify_type, run_date):
    job_id = f"{notify_type}_{user_id}_{run_date.timestamp()}"
    if notify_type == 'collect':
        scheduler.add_job(
            send_collect_notification,
            'date',
            run_date=run_date,
            args=[user_id, bot],
            id=job_id,
            replace_existing=True
        )
    elif notify_type == 'hunt':
        scheduler.add_job(
            send_hunt_notification,
            'date',
            run_date=run_date,
            args=[user_id, bot],
            id=job_id,
            replace_existing=True
        )

