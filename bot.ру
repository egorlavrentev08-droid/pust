async def clan_create(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if len(context.args) < 2:
        await update.message.reply_text("❌ Использование: /clan create [название]")
        return
    name = ' '.join(context.args[1:])
    session = Session()
    user = session.query(User).filter_by(user_id=update.effective_user.id).first()
    if not user:
        await update.message.reply_text("❌ Сначала используйте /start")
        session.close()
        return
    if user.clan_id:
        await update.message.reply_text("❌ Вы уже в клане.")
        session.close()
        return
    if user.level < 5:
        await update.message.reply_text("❌ Нужен 5 уровень.")
        session.close()
        return
    if user.radcoins < 1000:
        await update.message.reply_text("❌ Нужно 1000 RC.")
        session.close()
        return
    existing = session.query(Clan).filter_by(name=name).first()
    if existing:
        await update.message.reply_text("❌ Клан с таким названием уже есть.")
        session.close()
        return
    clan = Clan(name=name, leader_id=user.user_id)
    session.add(clan)
    session.flush()
    user.clan_id = clan.id
    user.radcoins -= 1000
    session.commit()
    await update.message.reply_text(f"✅ Клан {name} создан!")
    session.close()

