async def collect(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    username = update.effective_user.username
    session = Session()
    user = session.query(User).filter_by(user_id=user_id).first()
    if not user:
        user = User(user_id=user_id, username=username)
        session.add(user)
        session.commit()
    
    now = datetime.now()
    if user.next_collection_time and now < user.next_collection_time:
        remaining = user.next_collection_time - now
        hours = remaining.seconds // 3600
        minutes = (remaining.seconds % 3600) // 60
        await update.message.reply_text(f"⏰ Следующий сбор через {hours}ч {minutes}мин.")
        session.close()
        return
    
    actual_level = user.level
    if user.energy_drink_until and user.energy_drink_until > now:
        actual_level = min(user.level + 5, 100)
    
    base_rc = calculate_reward(actual_level)
    exp_gain = calculate_experience()
    
    clan_bonus = 0
    if user.clan_id:
        clan = session.query(Clan).filter_by(id=user.clan_id).first()
        if clan:
            clan_bonus = clan.collect_bonus
            exp_gain = int(exp_gain * (1 + clan.exp_bonus * 0.05))
    
    rc_gain = int(base_rc * (1 + clan_bonus / 100))
    
    if user.pet == 'рысь':
        rc_gain = int(rc_gain * 1.1)
    if user.pet == 'попугай':
        exp_gain = int(exp_gain * 1.4)
    
    multiplier = 1
    double_chance = 9
    if user.clan_id:
        clan = session.query(Clan).filter_by(id=user.clan_id).first()
        if clan:
            double_chance += clan.double_bonus
    if random.random() < 0.01:
        multiplier = 5
        user.crit_collects += 1
    elif random.random() < double_chance / 100:
        multiplier = 2
        user.crit_collects += 1
    rc_gain *= multiplier
    
    fragment_gain = 0
    fragment_chance = 1
    if user.pet == 'овчарка':
        fragment_chance += 5
    if random.random() < fragment_chance / 100:
        fragment_gain = 1
    
    if user.detectors > 0:
        user.detectors -= 1
        rc_gain = int(rc_gain * 0.3)
        if random.random() < 0.25:
            fragment_gain = 10
    
    meet_chance = 10
    if user.camouflage_until and user.camouflage_until > now:
        meet_chance = 1
    if user.pet == 'лис':
        meet_chance = meet_chance // 2 if meet_chance > 1 else 1
    
    lost_rc = 0
    if random.random() < meet_chance / 100:
        loss_percent = 50
        if user.shield_until and user.shield_until > now:
            loss_percent = 10
        lost_rc = int(rc_gain * loss_percent / 100)
        rc_gain -= lost_rc
    
    crystal_gain = 0
    if user.clan_id:
        crystal_gain = random.randint(1, 5)
        if user.pet == 'пума':
            crystal_gain = int(crystal_gain * 1.5)
        clan = session.query(Clan).filter_by(id=user.clan_id).first()
        if clan:
            clan.treasury_crystals += crystal_gain
    
    user.radcoins += rc_gain
    user.radfragments += fragment_gain
    user.experience += exp_gain
    user.total_collects += 1
    user.total_rc_earned += rc_gain
    if rc_gain > user.best_collect:
        user.best_collect = rc_gain
    
    level_up = False
    while user.experience >= get_exp_for_level(user.level + 1):
        user.level += 1
        level_up = True
    
    interval = get_random_interval(user)
    user.last_collection = now
    user.next_collection_time = now + timedelta(minutes=interval)
    
    last_date = user.last_collect_date.date() if user.last_collect_date else None
    today = now.date()
    if last_date == today - timedelta(days=1):
        user.daily_streak += 1
    elif last_date != today:
        user.daily_streak = 1
    user.last_collect_date = now
    
    pet_encounter = None
    phase = context.bot_data.get('phase', 2)
    if phase >= 2 and user.level >= 2:
        if random.random() < 0.0001:
            pets = ['овчарка', 'волк', 'алабай', 'рысь', 'пума', 'попугай', 'лис', 'кайот']
            weights = [1,1,1,1,1,1,1,0.5]
            pet_encounter = random.choices(pets, weights=weights)[0]
    
    session.commit()
    
    msg = f"🎲 Сбор: +{rc_gain} RC, +{exp_gain} опыта."
    if multiplier > 1:
        msg += f" ✨ x{multiplier}!"
    if fragment_gain > 0:
        msg += f" ☣️ +{fragment_gain} RF!"
    if lost_rc > 0:
        msg += f" 😈 Мутант украл {lost_rc} RC!"
    if crystal_gain > 0:
        msg += f" 💎 +{crystal_gain} RCr (клан)!"
    if level_up:
        msg += f" 🎉 Новый уровень: {user.level}!"
    if pet_encounter:
        msg += f"\n🐾 Вы встретили {pet_encounter}! Приручить? /pet accept / /pet deny"
        context.user_data['pending_pet'] = pet_encounter
    
    next_hours = interval // 60
    next_minutes = interval % 60
    msg += f"\n⏰ Следующий сбор через {next_hours}ч {next_minutes}мин."
    
    await update.message.reply_text(msg)
    session.close()

async def hunt(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    session = Session()
    user = session.query(User).filter_by(user_id=user_id).first()
    if not user:
        await update.message.reply_text("❌ Сначала используйте /start")
        session.close()
        return
    
    now = datetime.now()
    if user.last_hunt and now - user.last_hunt < timedelta(days=1):
        await update.message.reply_text("⏰ Охота доступна раз в сутки.")
        session.close()
        return
    
    rifle = user.rifles > 0
    if rifle:
        user.rifles -= 1
        chances = [60, 8, 30, 2]
    else:
        chances = [90, 10, 0.99, 0.01]
    
    roll = random.random() * 100
    if roll < chances[0]:
        reward = 1
        target_name = "Мутант 1 уровня"
    elif roll < chances[0] + chances[1]:
        reward = 3
        target_name = "Мутант 2 уровня"
    elif roll < chances[0] + chances[1] + chances[2]:
        reward = 10
        target_name = "Мутант 3 уровня"
        user.mutants_lvl3 += 1
    else:
        reward = 100
        target_name = "👑 Босс Пустоши"
        user.bosses_killed += 1
    
    user.mutants_killed += 1
    survived = True
    death_msg = ""
    
    if reward == 100:
        survive_chance = 10
        if user.armor_rank == 1:
            survive_chance = 33
        elif user.armor_rank == 2:
            survive_chance = 67
        elif user.armor_rank == 3:
            survive_chance = 99
        if user.pet == 'волк':
            survive_chance += 10
        survive_chance = min(99, survive_chance)
        if random.random() * 100 > survive_chance:
            survived = False
            if user.medkits > 0:
                if random.random() < 0.5:
                    survived = True
                    user.medkits -= 1
                    death_msg = " 💊 Аптечка спасла вас!"
                elif user.medkits > 1 and random.random() < 0.5:
                    survived = True
                    user.medkits -= 2
                    death_msg = " 💊💊 Аптечки спасли!"
            if not survived:
                user.deaths += 1
                user.armor_rank = 0
                user.medkits = 0
                user.harpoons = 0
                user.rifles = 0
                user.detectors = 0
                if user.shield_until:
                    user.shield_until -= timedelta(days=1)
                if user.camouflage_until:
                    user.camouflage_until -= timedelta(days=1)
                reward = 0
                death_msg = " 💀 Вы погибли! Броня и расходники потеряны."
    
    if survived:
        user.radfragments += reward
    user.last_hunt = now
    session.commit()
    
    text = f"🏹 {target_name}! +{reward} RF.{death_msg} ⏰ Следующая охота через 24ч."
    await update.message.reply_text(text)
    session.close()

