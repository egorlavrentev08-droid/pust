def schedule_notification(user_id, bot, notify_type, run_date):
    job_id = f"{notify_type}_{user_id}_{run_date.timestamp()}"
    if notify_type == 'collect':
        scheduler.add_job(
            send_collect_notification,
            'date',
            run_date=run_date,
            args=[user_id, bot],
            id=job_id,
            replace_existing=True
        )
    elif notify_type == 'hunt':
        scheduler.add_job(
            send_hunt_notification,
            'date',
            run_date=run_date,
            args=[user_id, bot],
            id=job_id,
            replace_existing=True
        )

